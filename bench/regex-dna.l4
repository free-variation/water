\ regex-dna — logicforth port of CPython pyperformance bm_regex_dna.
\
\ Generates the same FASTA as CPython (LCG, seed 42, length 100000), then
\ runs the measured phase: strip headers/newlines, count 9 variant patterns,
\ apply 11 IUB substitutions. Generation is not the timed part in CPython;
\ here it just has to produce byte-identical input.
\
\ Golden output (CPython), in print order:
\   1016745                                  ilen
\   1000000                                  clen
\   6 26 86 58 113 31 31 32 43               the nine variant counts
\   1336326                                  final length

100000 to N

\ a one-character newline string (string literals are raw; the newline is
\ the literal character between the quotes)
"
" to nl

\ ALU source (287 characters)
"GGCCGGGCGCGGTGGCTCACGCCTGTAATCCCAGCACTTTGGGAGGCCGAGGCGGGCGGATCACCTGAGGTCAGGAGTTCGAGACCAGCCTGGCCAACATGGTGAAACCCCGTCTCTACTAAAAATACAAAAATTAGCCGGGCGTGGTGGCGCGCGCCTGTAATCCCAGCTACTCGGGAGGCTGAGGCAGGAGAATCGCTTGAACCCGGGAGGCGGAGGTTGCAGTGAGCCGAGATCGCGCCACTGCACTCCAGCCTGGGCGACAGAGCGAGACTCCGTCTCAAAAA" to alu

\ frequency tables: base probabilities in table order, parallel char arrays
[ 0.27 0.12 0.12 0.27 0.02 0.02 0.02 0.02 0.02 0.02 0.02 0.02 0.02 0.02 0.02 ] to iub-base
[ "a" "c" "g" "t" "B" "D" "H" "K" "M" "N" "R" "S" "V" "W" "Y" ] to iub-chars
[ 0.3029549426680 0.1979883004921 0.1975473066391 0.3015094502008 ] to homo-base
[ "a" "c" "g" "t" ] to homo-chars

variable iub-cum
variable homo-cum
variable rng-seed

\ running cumulative sum of probabilities (matches CPython make_cumulative)
: cumulative ( probs -- cumulative )
  | >probs n out acc |
  probs size to n
  0.0 n array-of to out
  0.0 to acc
  [: dup probs swap @i  acc + to acc  out swap acc !i drop :] n i-times
  out ;

\ advance the LCG, return seed / 139968 in [0, 1)
: next-u ( -- u )
  rng-seed 3877.0 *  29573.0 +  139968.0 mod  dup to rng-seed
  139968.0 / ;

\ first index whose cumulative probability exceeds u (bisect_right)
: bisect ( u cum -- i )
  |> u cum |
  0
  begin
    dup cum swap @i  u gt  0=
  while
    1+
  repeat ;

\ one random character
: draw ( cum chars -- char )
  |> cum chars |
  next-u cum bisect
  chars swap @i ;

\ n random characters as one string, in draw order
: random-content ( cum chars n -- string )
  | >cum >chars >n out |
  "" n array-of to out
  [: out swap  cum chars draw  !i drop :] n i-times
  out "" join ;

\ src tiled/truncated to exactly len characters
: tile ( src len -- string )
  |> src len |
  src
  begin dup size len lt while dup + repeat
  0 len substring ;

\ break s into width-wide lines, each ending in a newline
: wrap ( s width -- wrapped )
  | >s >width slen lines out i |
  s size to slen
  slen width +  1-  width quotient  to lines
  "" lines array-of to out
  [: to i
     out i
       s  i width *  dup width +  dup slen gt if drop slen then  substring  nl +
     !i drop :] lines i-times
  out "" join ;

\ "name" -> "name\n"
: header ( name -- header-line )  nl + ;

\ assemble the FASTA: headers + three wrapped blocks. The IUB block draws
\ before the Homo block, so the shared rng-seed threads correctly.
: build-fasta ( -- seq )
  | seq |
  iub-base  cumulative to iub-cum
  homo-base cumulative to homo-cum
  42.0 to rng-seed

  ">ONE Homo sapiens alu" header  to seq
  seq  alu N 2 * tile  60 wrap  +  to seq
  seq  ">TWO IUB ambiguity codes" header  +  to seq
  seq  iub-cum iub-chars  N 3 *  random-content  60 wrap  +  to seq
  seq  ">THREE Homo sapiens frequency" header  +  to seq
  seq  homo-cum homo-chars  N 5 *  random-content  60 wrap  +  to seq
  seq ;

\ match-all returns 0 (not an array) on no match
: count-matches ( str pat -- n )
  match-all dup if size else drop 0 then ;

\ the timed phase — strip, 9 counts, 11 substitutions; results discarded
: work ( seq -- )
  | >seq stripped |
  seq  ">.*\n|\n"  "" replace  to stripped
  stripped "agggtaaa|tttaccct"          count-matches drop
  stripped "[cgt]gggtaaa|tttaccc[acg]"  count-matches drop
  stripped "a[act]ggtaaa|tttacc[agt]t"  count-matches drop
  stripped "ag[act]gtaaa|tttac[agt]ct"  count-matches drop
  stripped "agg[act]taaa|ttta[agt]cct"  count-matches drop
  stripped "aggg[acg]aaa|ttt[cgt]ccct"  count-matches drop
  stripped "agggt[cgt]aa|tt[acg]accct"  count-matches drop
  stripped "agggta[cgt]a|t[acg]taccct"  count-matches drop
  stripped "agggtaa[cgt]|[acg]ttaccct"  count-matches drop
  stripped
    "B" "(c|g|t)"   replace
    "D" "(a|g|t)"   replace
    "H" "(a|c|t)"   replace
    "K" "(g|t)"     replace
    "M" "(a|c)"     replace
    "N" "(a|c|g|t)" replace
    "R" "(a|g)"     replace
    "S" "(c|g)"     replace
    "V" "(a|c|g)"   replace
    "W" "(a|t)"     replace
    "Y" "(c|t)"     replace
  drop ;

\ same phase, printing one verification line: result: ilen clen <9 counts> flen
: report ( seq -- )
  | >seq stripped |
  "result:" .
  seq size .
  seq  ">.*\n|\n"  "" replace  to stripped
  stripped size .
  stripped "agggtaaa|tttaccct"          count-matches .
  stripped "[cgt]gggtaaa|tttaccc[acg]"  count-matches .
  stripped "a[act]ggtaaa|tttacc[agt]t"  count-matches .
  stripped "ag[act]gtaaa|tttac[agt]ct"  count-matches .
  stripped "agg[act]taaa|ttta[agt]cct"  count-matches .
  stripped "aggg[acg]aaa|ttt[cgt]ccct"  count-matches .
  stripped "agggt[cgt]aa|tt[acg]accct"  count-matches .
  stripped "agggta[cgt]a|t[acg]taccct"  count-matches .
  stripped "agggtaa[cgt]|[acg]ttaccct"  count-matches .
  stripped
    "B" "(c|g|t)"   replace
    "D" "(a|g|t)"   replace
    "H" "(a|c|t)"   replace
    "K" "(g|t)"     replace
    "M" "(a|c)"     replace
    "N" "(a|c|g|t)" replace
    "R" "(a|g)"     replace
    "S" "(c|g)"     replace
    "V" "(a|c|g)"   replace
    "W" "(a|t)"     replace
    "Y" "(c|t)"     replace
  size .
  cr ;

\ one timed run of the phase, in seconds
: timed ( seq -- seconds )
  | >seq t0 |
  now to t0
  seq work
  now t0 - ;

variable seq-data
build-fasta to seq-data
seq-data report
seq-data timed "elapsed: {0} s" format . cr
