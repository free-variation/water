\ regex-dna — port of CPython pyperformance bm_regex_dna
\
\ Generates the same FASTA the CPython benchmark generates (LCG, seed 42,
\ default length 100000), then performs the measured work: strip the header
\ and newline characters, count nine variant patterns, apply eleven IUB
\ substitutions. In CPython only the strip/count/substitute phase is timed;
\ the FASTA generation runs once outside the timed region, so its speed does
\ not matter here — only that it produces byte-identical input.
\
\ WON'T RUN YET. Depends on string words that are specified in PLAN.md but
\ not yet implemented:
\   ~...~        regex literal (regex escape conventions; \n is a newline)
\   match-all    ( string pattern -- [ [whole caps...] ... ] | 0 )
\   replace      ( string pattern replacement -- string' )  replace-all
\   substring    ( string start end -- substring )          half-open
\   join         ( array-of-strings -- string )             linear builder
\ Everything else (+ concat, size, @i, !i, array-of, arithmetic, locals,
\ control flow) already exists.
\
\ `join` and `substring` are the generator's only extra needs. `join` is
\ split's inverse and the linear string builder; without it, assembling a
\ ~1 MB string by repeated `+` is quadratic. They are not used by the timed
\ phase, which is purely ~...~ / match-all / replace / size.
\
\ Golden output for length 100000 (from CPython), in print order:
\   1016745            ilen
\   1000000            clen
\   6   26   86   58   113   31   31   32   43        the nine variant counts
\   1336326            final length after substitutions

\ ---- parameters ----

100000 to N

\ a one-character newline string (string literals are raw, so an escape
\ would not work here — the newline is the literal character between quotes)
"
" to nl

\ ---- ALU source (287 characters) ----

"GGCCGGGCGCGGTGGCTCACGCCTGTAATCCCAGCACTTTGGGAGGCCGAGGCGGGCGGATCACCTGAGGTCAGGAGTTCGAGACCAGCCTGGCCAACATGGTGAAACCCCGTCTCTACTAAAAATACAAAAATTAGCCGGGCGTGGTGGCGCGCGCCTGTAATCCCAGCTACTCGGGAGGCTGAGGCAGGAGAATCGCTTGAACCCGGGAGGCGGAGGTTGCAGTGAGCCGAGATCGCGCCACTGCACTCCAGCCTGGGCGACAGAGCGAGACTCCGTCTCAAAAA" to alu

\ ---- frequency tables ----
\ base probabilities in table order; cumulative arrays are summed in the
\ same order CPython's make_cumulative uses, so the bisect boundaries match.

[ 0.27 0.12 0.12 0.27 0.02 0.02 0.02 0.02 0.02 0.02 0.02 0.02 0.02 0.02 0.02 ] to iub-base

[ "a" "c" "g" "t" "B" "D" "H" "K" "M" "N" "R" "S" "V" "W" "Y" ] to iub-chars

[ 0.3029549426680 0.1979883004921 0.1975473066391 0.3015094502008 ] to homo-base

[ "a" "c" "g" "t" ] to homo-chars

variable iub-cum
variable homo-cum

\ ( probs -- cumulative )  running sum, matching make_cumulative
: cumulative
  | probs n out acc |
  probs size to n
  0.0 n array-of to out
  0.0 to acc
  [: dup probs swap @i  acc + to acc  out swap acc !i drop :] n i-times
  out ;

\ ---- pseudo-random generator (the benchmark's own LCG, not the language's) ----

variable rng-seed

\ ( -- u )  advance the LCG, return seed / 139968 in [0, 1)
: next-u
  rng-seed 3877.0 *  29573.0 +  139968.0 mod  dup to rng-seed
  139968.0 / ;

\ ( u cum -- i )  first index whose cumulative probability exceeds u
\ (bisect_right): continue while cum[i] <= u
: bisect
  | u cum |
  0
  begin
    dup cum swap @i  u gt  0=
  while
    1+
  repeat ;

\ ( cum chars -- char )  one random character
: draw
  | cum chars |
  next-u cum bisect
  chars swap @i ;

\ ( cum chars n -- content )  n random characters, in draw order
: random-content
  | cum chars n out |
  "" n array-of to out
  [: out swap  cum chars draw  !i drop :] n i-times
  out join ;

\ ---- line wrapping ----

\ ( src len -- string )  src tiled/truncated to exactly len characters
: tile
  | src len |
  src
  begin dup size len lt while dup + repeat
  0 len substring ;

\ ( s width -- wrapped )  break s into width-wide lines, each ending in
\ a newline (the last line holds the remainder), matching FASTA output
: wrap
  | s width slen lines out i |
  s size to slen
  slen width +  1-  width quotient  to lines
  "" lines array-of to out
  [: to i
     out i
       s  i width *  dup width +  dup slen gt if drop slen then  substring  nl +
     !i drop :] lines i-times
  out join ;

\ ---- assemble the FASTA input ----

\ ( -- seq )  headers + three wrapped sequence blocks, identical to CPython.
\ The IUB block must be generated before the Homo block: both draw from the
\ shared rng-seed, and the Homo block continues the sequence the IUB block
\ left off.
: build-fasta
  iub-base  cumulative to iub-cum
  homo-base cumulative to homo-cum
  42.0 to rng-seed

  ">ONE Homo sapiens alu" nl +
    alu  N 2 *  tile  60 wrap  +
  ">TWO IUB ambiguity codes" nl +
    iub-cum iub-chars   N 3 *  random-content  60 wrap  +
  ">THREE Homo sapiens frequency" nl +
    homo-cum homo-chars  N 5 *  random-content  60 wrap  + ;

\ ---- the measured work ----

\ ( str pattern -- count )  match-all returns 0 (not an array) on no match
: count-matches
  match-all dup if size else drop 0 then ;

: regex-dna
  | seq stripped |
  build-fasta to seq
  seq size . cr                                 \ ilen

  seq ~>.*\n|\n~ "" replace to stripped
  stripped size . cr                            \ clen

  stripped ~agggtaaa|tttaccct~           count-matches . cr
  stripped ~[cgt]gggtaaa|tttaccc[acg]~   count-matches . cr
  stripped ~a[act]ggtaaa|tttacc[agt]t~   count-matches . cr
  stripped ~ag[act]gtaaa|tttac[agt]ct~   count-matches . cr
  stripped ~agg[act]taaa|ttta[agt]cct~   count-matches . cr
  stripped ~aggg[acg]aaa|ttt[cgt]ccct~   count-matches . cr
  stripped ~agggt[cgt]aa|tt[acg]accct~   count-matches . cr
  stripped ~agggta[cgt]a|t[acg]taccct~   count-matches . cr
  stripped ~agggtaa[cgt]|[acg]ttaccct~   count-matches . cr

  stripped
    ~B~ "(c|g|t)"   replace
    ~D~ "(a|g|t)"   replace
    ~H~ "(a|c|t)"   replace
    ~K~ "(g|t)"     replace
    ~M~ "(a|c)"     replace
    ~N~ "(a|c|g|t)" replace
    ~R~ "(a|g)"     replace
    ~S~ "(c|g)"     replace
    ~V~ "(a|c|g)"   replace
    ~W~ "(a|t)"     replace
    ~Y~ "(c|t)"     replace
  size . cr ;                                   \ final length

regex-dna
