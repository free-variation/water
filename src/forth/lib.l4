( a b -- a b a b )
: 2dup over over ;


\ matrix words

\ broadcast a scalar to the dimension of the preceding matrix
( m scalar -- m broadcast-scalar )
: scalar-op
	over dim * array
	over dim matrix
;

: scalar+ scalar-op + ;
: scalar- scalar-op - ;
: scalar* scalar-op * ;
: scalar/ scalar-op / ;

: identity-matrix 1 swap diagonal-matrix ;
 
