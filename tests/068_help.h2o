\ man ( xt -- fr ): frame of a word's reference entry, or null if undocumented.
\ lookup ( "name" -- xt ): parse the next word at run time, push its xt.
\ help ( "name" -- ): lib.h2o convenience, prints a word's man frame.

\ a runtime word: the three base keys carry the documented strings
' sin man :word @ "sin" = . cr                    \ 1
' sin man :effect @ "( a -- sin a )" = . cr       \ 1
' sin man :summary @ "sine (radians)" = . cr      \ 1

\ a runtime word also carries the three cost keys, as strings
' sin man :ops has? . cr                          \ 1
' sin man :ops @ "2" = . cr                       \ 1
' sin man :alloc has? . cr                        \ 1
' sin man :order has? . cr                        \ 1
' sin man size . cr                               \ 6

\ a compile-time word has the base keys but no cost keys
' if man :word @ "if" = . cr                      \ 1
' if man :ops has? . cr                           \ 0
' if man :alloc has? . cr                         \ 0
' if man :order has? . cr                         \ 0
' if man size . cr                                \ 3

\ a lib.h2o word is documented like any other
' 2dup man :summary @ "lib.h2o: over over (inlined)" = . cr   \ 1

\ man resolves its own entry
' man man :word @ "man" = . cr                    \ 1

\ a word with no reference entry returns null
: fresh-this-session 1 ;
' fresh-this-session man null = . cr              \ 1

\ a unit word synthesizes its entry from the unit's definition
' kg man :summary @ "unit: base unit of its own dimension" = . cr   \ 1
' newton man :summary @ . cr                      \ unit: m.kg.s^-2
' km man :summary @ . cr                          \ unit: m × 1000
' ¢ man :effect @ "( n -- q )" = . cr             \ 1
base unit furlong
' furlong man null = . cr                         \ 0

\ see reconstructs a unit as a description line
' newton see

\ lookup parses the next word and pushes its xt
lookup sin man :word @ "sin" = . cr               \ 1

\ help parses the next word and prints its man frame
help sin

bye
