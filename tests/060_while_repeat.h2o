\ begin <cond> while <body> repeat — test-at-top loop. The condition is tested
\ each pass before the body; the body is skipped entirely if it's false at entry.

\ count 0..4
: count5 0 begin dup 5 < while dup . 1+ repeat drop ;
count5 cr

\ sum 1..10 = 55
: sum10 | i s | 0 to s 1 to i begin i 11 < while i s + to s i 1+ to i repeat s ;
sum10 . cr

\ body skipped when the condition is false on entry
: skip 0 begin dup 0 > while drop 99 repeat ;
skip . cr

\ countdown 3 2 1
: down 3 begin dup 0 > while dup . 1- repeat drop ;
down cr
