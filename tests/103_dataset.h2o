\ TSV -> dataset (column frame) and -> relation (indexed, deduped).
\ A dataset is just a frame: columns are reached with native @ / keys / values,
\ and a uniformly numeric column arrives as an n x 1 vector, flowing straight
\ into the matrix/stats side.

[ [ "name" "age" "city" ]
  [ "Alice" 30 "NYC" ]
  [ "Bob"   25 "LA"  ]
  [ "Cy"    40 "SF"  ] ] "/tmp/lf_ds.tsv" save-tsv
"/tmp/lf_ds.tsv" load-tsv 1 rows>dataset
dup keys . cr                           \ [ :name :age :city ]  column names, native frame keys
dup :name @ . cr                        \ [ "Alice" "Bob" "Cy" ]  string column
dup :age @ transpose . cr               \ 30 25 40 as 1x3 — a numeric column is a vector
dup :age @ sum . cr                     \ 95   straight into the matrix reductions
dup :age @ 1+ transpose . cr            \ 31 26 41  derive a column with broadcast arithmetic
drop

\ an empty cell becomes NaN in a numeric column
[ [ "name" "age" ]
  [ "Dan" null ]
  [ "Eve" 22 ] ] "/tmp/lf_ds.tsv" save-tsv
"/tmp/lf_ds.tsv" load-tsv 1 rows>dataset
:age @ transpose . cr                   \ nan 22 as 1x2

\ headerless: synthesized :col1 .. :colN, every row is data
[ [ 5 10 ] [ 6 11 ] [ 7 12 ] ] "/tmp/lf_ds.tsv" save-tsv
"/tmp/lf_ds.tsv" load-tsv 0 rows>dataset
dup keys . cr                           \ [ :col1 :col2 ]
:col2 @ transpose . cr                  \ 10 11 12 as 1x3

clear
\ dataset>rows ( dataset -- rows ): the inverse of true rows>dataset — row-arrays
\ led by a header row of the column names, columns in key order, NaN back to null.
[ [ "name" "age" ] [ "Alice" 30 ] [ "Bob" null ] ] true rows>dataset
dup dataset>rows .a cr                          \ header + data rows, null kept
dup dup dataset>rows true rows>dataset = . cr   \ 1   round trip is exact
dataset>rows "/tmp/lf_ds.tsv" save-tsv          \ feeds save-tsv directly
"/tmp/lf_ds.tsv" load-tsv 1 rows>dataset :age @ transpose . cr   \ 30 nan as 1x2
{ :height [ 170 180 ] vector m } dup dataset>rows true rows>dataset = . cr  \ 1  unit kept
{ } dataset>rows . cr                           \ [ ]
[ [ "k" ] ] true rows>dataset dataset>rows .a cr \ [ [ "k" ] ]  zero rows keep the header

\ rows>relation: indexed on :id, deduped (the repeated u1/NYC row collapses), queryable
[ [ "id" "city" ]
  [ "u1" "NYC" ]
  [ "u2" "LA"  ]
  [ "u1" "NYC" ] ] "/tmp/lf_ds.tsv" save-tsv
"/tmp/lf_ds.tsv" load-tsv [ :id ] 1 rows>relation
dup { } query size . cr                 \ 2   duplicate collapsed (relation is a set)
dup { :id :u2 } query . cr              \ [ { :city "LA" :id :u2 } ]
{ :id :u1 } count-matches . cr          \ 1

clear
\ select-rows ( dataset indices -- dataset ): every column gathered by the
\ same row indices — a float array or an index vector (as where/argsort
\ return). Matrix and dimensioned columns go through the matrix path and
\ keep their representation; array columns gather element-wise.
{ :name [ "ann" "bob" "cal" ]
  :height [ 170 180 190 ] vector m
  :score [ 5 1 4 ] vector } to selectable

selectable [ 2 0 ] select-rows . cr             \ cal/ann rows; height keeps m
selectable [ 2 0 ] vector select-rows . cr      \ same rows from an index vector
selectable selectable :score @ argsort select-rows . cr   \ sorted by score: bob cal ann
selectable selectable :score @ 3 gt where select-rows . cr \ scores over 3: ann cal
selectable [ 1 1 ] select-rows . cr             \ bob twice
selectable [ ] select-rows . cr                 \ zero rows, representations kept
{ } [ ] select-rows . cr                        \ { }
[ 5 1 4 ] vector [ 2 0 ] select-rows transpose . cr   \ 4 5 as 1x2 (matrix path intact)

\ errors
selectable [ 5 ] select-rows                    \ (array index 5 out of bounds; :name gathers first)
clear
{ :only [ "a" "b" ] } [ 3 ] select-rows         \ (array index 3 out of bounds)
clear
5 [ 0 ] select-rows                             \ (neither dataset nor matrix)

clear
\ dim ( dataset -- r c ): rows from the first column's length, columns from
\ the key count. column-type ( dataset sym -- sym ): the column's type from
\ its representation.
{ :name [ "ann" "bob" "cal" ]
  :height [ 170 180 190 ] vector m
  :score [ 5 1 4 ] vector
  :seen [ 100 200 300 ] vector s } to typed

typed dim . . cr                                \ 4 3  (columns then rows)
typed n-rows . typed n-columns . cr             \ 3 4
[ 1 2 3 4 5 6 ] 2 3 matrix n-rows . cr          \ 2
{ } dim . . cr                                  \ 0 0
{ :a [ ] } dim . . cr                           \ 1 0
[ 1 2 3 4 5 6 ] 2 3 matrix dim . . cr           \ 3 2  (matrix path intact)

typed :score column-type . cr                   \ :numeric
typed :height column-type . cr                  \ :quantity
typed :seen column-type . cr                    \ :datetime
typed :name column-type . cr                    \ :text
{ :a [ ] vector } :a column-type . cr           \ :numeric  (empty typed column)

\ errors
typed :missing column-type                      \ (no key :missing)

clear
\ column>array ( column -- arr ): any representation as an array of values.
\ column>set ( column -- set ): the column's distinct values.
typed :name @ column>array . cr                 \ arrays pass through
typed :score @ column>array . cr                \ floats from a vector
typed :height @ column>array . cr               \ quantities, unit kept
[ 1 null 1 ] vector column>array . cr           \ NaN back to null
[ "b" "a" "b" ] column>set . cr                 \ < a b >
typed :score @ column>set size . cr             \ 3
[ 2 2 2 ] vector column>set . cr                \ < 2 >

clear
\ select-columns ( dataset cols -- dataset ): the named columns as a new
\ dataset; the values are shared, the frame is fresh.
typed [ :name :score ] select-columns . cr      \ two of four columns
typed [ :height ] select-columns . cr           \ unit kept
typed [ ] select-columns . cr                   \ { }
typed [ :name ] select-columns dim . . cr       \ 1 3

\ errors
typed [ :nope ] select-columns                  \ (no key :nope)

clear
\ count ( arr/v/dataset -- pairs ): [ value n ] per distinct value, most
\ frequent first, ties in value order; a dataset counts whole rows as frames.
[ "b" "a" "b" "c" "b" "a" ] count . cr          \ b 3, a 2, c 1
[ 5 1 5 5 1 ] vector count . cr                 \ 5 3, 1 2
[ 10 10 20 ] vector m count . cr                \ quantities as values
[ 1 2 2 1 ] count . cr                          \ tie: value order
[ 7 ] count . cr                                \ singleton
[ ] count . cr                                  \ [ ]
{ :name [ "ann" "bob" "ann" ] :score [ 5 1 5 ] vector } count . cr
{ } count . cr                                  \ [ ]

\ errors
5 count                                         \ (not countable, sort rejects)

clear
\ group-indices ( column -- pairs ): [ value [indices] ] per distinct value
\ in val_cmp order; each index array ascending.
[ "b" "a" "b" "a" "b" ] group-indices . cr      \ a: 1 3; b: 0 2 4
[ 5 5 1 ] vector group-indices . cr             \ 1: 2; 5: 0 1
[ 1 2 3 ] group-indices . cr                    \ singletons
[ 1 null 1 null ] vector group-indices . cr     \ nulls group, ordered first
[ ] group-indices . cr                          \ [ ]
{ :name [ "ann" "bob" "ann" ] :score [ 5 1 4 ] vector } dup
:name @ group-indices 0 @i 1 @i select-rows . cr \ the ann rows

clear
\ filter ( dataset xt -- dataset ): keep the rows whose frame satisfies
\ xt ( row -- bool ); columns keep their representation via select-rows.
{ :name [ "ann" "bob" "cal" ]
  :score [ 5 1 4 ] vector
  :height [ 170 180 190 ] vector m } to filterable

filterable [: :score @ 3 gt :] filter . cr      \ ann and cal
filterable [: :name @ "bob" = :] filter . cr    \ bob alone
filterable [: drop 0 :] filter . cr             \ no rows, representations kept
{ } [: drop 1 :] filter . cr                    \ { }
[ 1 2 3 4 5 ] [: 2 mod 1 = :] filter . cr       \ [ 1 3 5 ] array path intact

clear
\ map-rows ( dataset xt -- dataset ): xt maps each row frame to a new row
\ frame; frames>dataset ( rows -- dataset ) rebuilds columns, inferring each
\ representation (floats -> vector with NaN for none, one-unit quantities ->
\ dimensioned vector, else array).
{ :name [ "ann" "bob" ] :height [ 170 180 ] vector m :score [ 5 1 ] vector } to mappable

mappable [> row | { :who row :name @ :ratio row :score @ row :height @ magnitude / } :] map-rows . cr
mappable [> row | row :double row :score @ 2 * ! :] map-rows . cr
{ } [: :] map-rows . cr                        \ { }

[ { :a 1 :b "x" } { :a 2 :b "y" } ] frames>dataset . cr
[ { :a 1 } { :a null } ] frames>dataset :a @ transpose . cr    \ 1 nan as 1x2
[ ] frames>dataset . cr                        \ { }
{ :when [ 100 200 ] vector s } [> row | { :later row :when @ 1 day + } :] map-rows
dup :later column-type . cr                     \ :datetime survives the rebuild
:later @ magnitude transpose . cr               \ 86500 86600 as 1x2

\ errors
[ { :a 1 } { :b 2 } ] frames>dataset            \ (rows have differing keys)

clear
\ nan? on an array: n x 1 mask of the none elements; select-rows on a bare
\ array gathers by a float index array or an index vector.
[ "a" null "b" null ] nan? transpose . cr       \ 0 1 0 1 as 1x4
[ "a" null "b" ] dup nan? 0 eq where select-rows . cr   \ complete cases
[ "a" null "b" ] dup nan? where select-rows . cr        \ the missing ones
[ ] nan? dim . . cr                             \ 1 0
[ 10 20 30 ] [ 2 0 ] select-rows . cr           \ [ 30 10 ]
[ 1 null 3 ] vector nan? transpose . cr         \ matrix path intact

clear
\ mesh ( v mask b -- v' ): masked substitution — replace where the mask is a
\ definite nonzero, keep where it is 0 or NaN (unknown changes nothing).
[ 1 null 3 ] vector dup nan? 0 mesh transpose . cr      \ fill NaNs: 1 0 3
[ 1 -1 3 ] vector dup -1 eq null mesh transpose . cr    \ sentinel to NaN: 1 nan 3
[ 5 20 8 ] vector dup 10 gt 10 mesh transpose . cr      \ cap: 5 10 8
[ 1 2 3 ] vector [ null 1 null ] vector 9 mesh transpose . cr  \ NaN mask keeps: 1 9 3
[ "a" null "b" ] dup nan? "?" mesh . cr                 \ text fill
[ "a" "b" ] dup [: "a" = :] map vector [ "X" "Y" ] mesh . cr   \ both-array pick

\ errors
[ 1 2 ] vector [ 1 0 1 ] vector 9 mesh                  \ (mask shape mismatch)
clear
[ 1 2 ] vector 1 [ 9 9 ] vector mesh                    \ (mask must be a matrix)

clear
\ replace-where ( dataset sym pred replacement -- ): conditionally edit one
\ column in place; pred is ( column -- mask ), the replacement broadcasts.
{ :rep_touches [ 3 -1 7 ] vector :name [ "a" null "c" ] } to editable
editable :rep_touches [: -1 eq :] null replace-where
editable :rep_touches @ transpose . cr          \ 3 nan 7
editable :rep_touches [: nan? :] 0 replace-where
editable :rep_touches @ transpose . cr          \ 3 0 7
editable :name [: nan? :] "?" replace-where
editable :name @ . cr                           \ [ "a" "?" "c" ]
{ :price [ 12 8 ] vector $ } to shop
shop :price [: 10 $ lt :] 5 $ replace-where
shop :price @ transpose . cr                    \ 12 5, unit kept

\ errors
editable :missing [: nan? :] 0 replace-where    \ (no key :missing)
