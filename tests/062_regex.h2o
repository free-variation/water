\ has? on a string ( string pattern -- bool ): does the string contain a match anywhere.
"hello world" "wor" has? . cr      \ -1
"hello world" "xyz" has? . cr      \ 0
"hello" "^h" has? . cr             \ -1  (anchored start)
"hello" "^e" has? . cr             \ 0
"chr12" "[0-9]+" has? . cr         \ -1  (char class)
"abc"   "[0-9]+" has? . cr         \ 0
{ :a 1 :b 2 } :a has? . cr         \ -1  (frame path still works)
{ :a 1 } :z has? . cr              \ 0
"x" "[" has? . cr                  \ bad pattern -> error

clear
\ match-all ( string pattern -- [ [whole caps...] ... ] | 0 ) — deep test.

\ --- structure: whole match plus capture groups, nested per match ---
"chr1chr2" "(chr)([0-9])" match-all . cr        \ [ [ chr1 chr 1 ] [ chr2 chr 2 ] ]

\ --- capture offsets stay correct across later matches (the +from shift) ---
"x=1; y=2; z=3" "([a-z])=([0-9])" match-all . cr

\ --- no capture groups: each match is a one-element array ---
"a1b2c3" "[0-9]" match-all . cr                 \ [ [ 1 ] [ 2 ] [ 3 ] ]

\ --- non-participating group (alternation branch that didn't fire) -> 0 ---
"ab" "(a)|(b)" match-all . cr                   \ [ [ a a 0 ] [ b 0 b ] ]

\ --- a group that MATCHED EMPTY ("") is distinct from non-participating (0) ---
"b" "(a*)(b)" match-all . cr                    \ [ [ b "" b ] ]

\ --- non-overlapping, leftmost ---
"aaaa" "aa" match-all size . cr                 \ 2

\ --- zero-width matches advance one char (Python findall parity) ---
"baab" "a*" match-all size . cr                 \ 4

\ --- anchors honor REG_NEWLINE across embedded newlines ---
"a
b
c" "^[a-z]" match-all size . cr                 \ 3  (^ at each line start)
"a
b" "[a-z]$" match-all size . cr                 \ 2  ($ at each line end)

\ --- whole-string single match ---
"agggtaaa" "agggtaaa|tttaccct" match-all size . cr   \ 1

\ --- boundaries: empty subject ---
"" "a" match-all . cr                           \ 0
"" "a*" match-all size . cr                     \ 1  (one empty match)

\ --- no match anywhere ---
"hello" "z" match-all . cr                      \ 0

\ --- Unicode (UTF mode): . matches whole codepoints, \d/\w are UCP-aware ---
"café" "." match-all size . cr                  \ 4  (codepoints, not 5 bytes)
"x😀y" "." match-all size . cr                  \ 3  (emoji is one codepoint)
"a1٢3" "\d+" match-all size . cr                \ 1  (٢ U+0662 is a Unicode digit)

\ --- errors ---
"x" "(" match-all                               \ bad pattern
5 "a" match-all                                 \ non-string subject
"x" 5 match-all                                 \ non-string pattern

clear
\ replace ( string pattern replacement -- string' ) — replace-all (gsub). Deep test.

\ --- replace-all, growing the string ---
"hello" "l" "L" replace . cr                  \ heLLo
"BBBB" "B" "(c|g|t)" replace . cr             \ (c|g|t)(c|g|t)(c|g|t)(c|g|t)

\ --- no match -> unchanged ---
"abc" "z" "Q" replace . cr                    \ abc

\ --- whole match via & and \0 ---
"axbxc" "x" "[&]" replace . cr                \ a[x]b[x]c
"axb" "x" "<\0>" replace . cr                 \ a<x>b

\ --- capture backrefs ---
"chr1 chr2" "(chr)([0-9])" "\2:\1" replace . cr   \ 1:chr 2:chr
"hello" "(l+)" "<\1>" replace . cr            \ he<ll>o

\ --- escapes: \& literal ampersand, \\ literal backslash ---
"x" "x" "\&\&" replace . cr                   \ &&
"x" "x" "a\\b" replace . cr                   \ a\b

\ --- non-participating group backref inserts nothing ---
"ab" "(a)|(b)" "[\1\2]" replace . cr          \ [a][b]

\ --- deletion (empty replacement) ---
"a-b-c" "-" "" replace . cr                   \ abc

\ --- zero-width matches ---
"a" "b*" "X" replace . cr                     \ XaX
"abc" "x*" "-" replace . cr                   \ -a-b-c-

\ --- literal newline in the pattern (real newline; ~...~ not in yet): newlines -> spaces ---
"a
b
c" "
" " " replace . cr                            \ a b c

\ --- chained substitutions (IUB style) ---
"aBcD" "B" "(c|g|t)" replace "D" "(a|g|t)" replace . cr   \ a(c|g|t)c(a|g|t)

\ --- empty subject ---
"" "a" "X" replace . cr                       \ (empty)

\ --- errors ---
"x" "(" "y" replace                           \ bad pattern
"x" "x" "\3" replace                          \ backref out of range
5 "a" "b" replace                             \ non-string subject
"x" 5 "b" replace                             \ non-string pattern
"x" "a" 5 replace                             \ non-string replacement

clear
\ match ( string pattern -- [ whole caps... ] | 0 ) — first match only, flat.

\ --- structure: whole match plus capture groups, flat (not nested) ---
"chr1chr2" "(chr)([0-9])" match . cr            \ [ chr1 chr 1 ]

\ --- first match only (match-all would find both) ---
"x=1; y=2; z=3" "([a-z])=([0-9])" match . cr    \ [ x=1 x 1 ]

\ --- no capture groups: a one-element array ---
"a1b2c3" "[0-9]" match . cr                     \ [ 1 ]

\ --- non-participating group (alternation branch that didn't fire) -> 0 ---
"ab" "(a)|(b)" match . cr                        \ [ a a 0 ]

\ --- a group that MATCHED EMPTY ("") is distinct from non-participating (0) ---
"b" "(a*)(b)" match . cr                         \ [ b "" b ]

\ --- leftmost match wins ---
"xxhello" "hello" match . cr                     \ [ hello ]

\ --- anchors honor multiline; first match is on the first line ---
"a
b
c" "^[a-z]" match . cr                           \ [ a ]

\ --- whole-string single match ---
"agggtaaa" "agggtaaa|tttaccct" match . cr        \ [ agggtaaa ]

\ --- boundaries: empty subject ---
"" "a" match . cr                                \ 0
"" "a*" match . cr                               \ [ "" ]  (one empty match)

\ --- no match anywhere ---
"hello" "z" match . cr                           \ 0

\ --- Unicode (UTF mode + UCP): \w is accent-aware, . matches a codepoint ---
"café" "\w+" match . cr                          \ [ café ]
"naïve_x" "^\w+$" match . cr                     \ [ naïve_x ]  (all word chars)
"a→b" "." match . cr                             \ [ a ]        (first codepoint)

\ --- errors ---
"x" "(" match                                    \ bad pattern
5 "a" match                                      \ non-string subject
"x" 5 match                                      \ non-string pattern

clear
\ split ( string pattern -- [ piece … ] ) — deep test. Regex delimiter,
\ empty fields kept; the pieces are the gaps between match-all's matches.

\ basic comma split
"a,b,c" "," split .                     \ [ "a" "b" "c" ]

\ empty fields are kept
"a,,b" "," split .                      \ [ "a" "" "b" ]

\ leading and trailing empties
",a," "," split .                       \ [ "" "a" "" ]

\ no delimiter present -> the whole string as one piece
"nodelim" "," split .                   \ [ "nodelim" ]

\ empty subject -> one empty piece
"" "," split .                          \ [ "" ]

\ multi-character delimiter
"a::b::c" "::" split .                  \ [ "a" "b" "c" ]

\ regex delimiter: one or more spaces
"a  b c" " +" split .                   \ [ "a" "b" "c" ]

\ split then join on the same literal delimiter round-trips
"x,y,z" "," split "," join  "x,y,z" =  . cr   \ 1

\ error: pattern is not a string
"x" 5 split
