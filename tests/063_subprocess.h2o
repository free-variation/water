\ read ( stream -- string ) — deep test: read a child's :out to EOF.

\ exact bytes, no trailing newline (printf)
[ "printf" "abc" ] start-process :out @ read  "abc" =  . cr        \ 1

\ echo appends a newline
[ "echo" "hi" ] start-process :out @ read  "hi
" =  . cr

\ embedded newlines are preserved: printf "a\nb\nc" -> 5 bytes
[ "printf" "a\nb\nc" ] start-process :out @ read size . cr         \ 5

\ empty output -> ""
[ "true" ] start-process :out @ read  "" =  . cr                   \ 1

\ a second read on an exhausted stream yields ""
[ "echo" "x" ] start-process :out @  dup read drop  read "" =  . cr   \ 1

\ large output exercises the buffer growth (> 64 KiB)
[ "seq" "1" "20000" ] start-process :out @ read size . cr

\ the :err stream is readable too
[ "sh" "-c" "printf oops >&2" ] start-process :err @ read  "oops" =  . cr  \ 1

\ error: read on a non-stream
5 read

\ --- cwd ( -- path ): current working directory, non-empty.
cwd size 0 > . cr
\ --- cd ( path -- ): change working dir; root "/" is portable across machines.
"/" cd cwd "/" = . cr
\ --- cd is inherited by children across fork.
[ "pwd" ] start-process :out @ read trim "/" = . cr
\ --- cd failure leaves the directory unchanged and names the path.
"/no/such/dir" cd
\ --- end-process ( proc -- ): closes the streams (a later read fails) and reaps the child.
[ "echo" "hi" ] start-process dup end-process :out @ read

clear
\ write ( string stream -- ) — deep test.
\ head -c N self-terminates after N bytes, so written bytes round-trip
\ through the pipe and back out without needing close.

\ one write; the consumer echoes the first 5 bytes
[ "head" "-c" "5" ] start-process
  dup  "hello world" swap :in @  write
  :out @ read  "hello" =  . cr        \ 1

\ sequential writes arrive in order
[ "head" "-c" "6" ] start-process
  dup  "foo" swap :in @  write
  dup  "bar" swap :in @  write
  :out @ read  "foobar" =  . cr       \ 1

\ an empty write is a no-op (the loop never runs), no error
[ "head" "-c" "2" ] start-process
  dup  "" swap :in @  write
  dup  "hi" swap :in @  write
  :out @ read  "hi" =  . cr           \ 1

\ binary-safe: bytes with embedded newline pass through unchanged
[ "head" "-c" "3" ] start-process
  dup  "a
b" swap :in @  write
  :out @ read  size . cr              \ 3

\ error: write target is not a stream
"x" 5 write

clear
\ close ( stream -- ) — closing :in sends the child EOF, letting a filter
\ (tr, cat, sort, …) finish and flush. Deep test of the round-trip
\ write-in -> close :in -> read-out.

\ feed input through a command and collect its stdout
: filter ( input cmd -- output )
  run swap over write-in  dup :in @ close  read-out ;

\ upcase
"hello world" "tr a-z A-Z" filter  "HELLO WORLD" =  . cr      \ 1

\ identity (cat) preserves the bytes exactly
"a,b,c" "cat" filter  "a,b,c" =  . cr                          \ 1

\ multi-line input passes through
"ab
cd" "tr a-z A-Z" filter  "AB
CD" =  . cr                                                     \ 1

\ sort can only emit after it sees the full input + EOF
"b
a
c
" "sort" filter  "a
b
c
" =  . cr                                                      \ 1

\ empty input: close with nothing written -> empty output
"" "cat" filter  "" =  . cr                                    \ 1

\ byte count of the round-tripped output
"12345" "cat" filter size .  cr                                \ 5

\ error: close on a non-stream
5 close

clear
\ wait ( pid -- status ) — block for the child, return its exit code,
\ or 128 + signal number if it was killed by a signal.

\ success and failure exit codes
[ "true" ]  start-process :pid @ wait .  cr               \ 0
[ "false" ] start-process :pid @ wait .  cr               \ 1

\ an arbitrary exit code passes through
[ "sh" "-c" "exit 42" ] start-process :pid @ wait .  cr   \ 42

\ death by signal -> 128 + signo (SIGKILL = 9 -> 137)
[ "sh" "-c" "kill -9 $$" ] start-process :pid @ wait .  cr   \ 137

\ wait after draining a round-trip: the filter exits 0
"head -c 3" run dup "hello" swap write-in  dup :in @ close
  dup read-out drop  :pid @ wait .  cr                    \ 0

\ error: pid must be a number
"x" wait

clear
\ stop ( pid -- status ) — SIGKILL the child and reap it. SIGKILL is
\ signal 9, so a killed child reports 128 + 9 = 137.

\ kill a long-running process
"sleep 60" run :pid @ stop .  cr        \ 137

\ a process blocked reading stdin (no input, never closed) is killed too
"cat" run :pid @ stop .  cr             \ 137

\ error: pid must be a number
"x" stop

clear
\ running? ( pid -- bool ) — non-blocking liveness via waitid(WNOHANG|WNOWAIT).
\ true while the child runs; false once it has exited. Non-reaping.

variable p

\ a long sleeper is alive
"sleep 60" run to p
p :pid @ running? .  cr          \ 1

\ ... and not alive once stopped (stop SIGKILLs and reaps it)
p :pid @ stop drop
p :pid @ running? .  cr          \ 0

\ a process already reaped by wait is likewise not running
[ "true" ] start-process to p
p :pid @ wait drop
p :pid @ running? .  cr          \ 0

\ error: pid must be a number
"x" running?

\ M11: a non-positive pid would broadcast (kill(0)=process group, kill(-1)=everyone);
\ a spawned child is always >] 0, so stop/wait reject pid <= 0 before kill/waitpid.
0 stop
-1 stop
0 wait
