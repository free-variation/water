\ Frames: { :sym val ... } literal, array>frame builder, @ path get.

\ literal, pretty-printed by .
{ :a 1 :b 2 } . cr

\ builder from a key/value array
[ :a 1 :b 2 ] array>frame . cr

\ keys are stored sorted regardless of insertion order
{ :b 2 :a 1 } . cr

\ nested frame literal
{ :a 1 :b { :c 2 } } . cr

\ @ : single-key get
{ :a 5 } [ :a ] @ . cr

\ @ : nested path get
{ :a { :b 7 } } [ :a :b ] @ . cr

\ @ : missing key errors
{ :a 1 } [ :z ] @ . cr

\ @ : symbol form takes the single-key fast path
{ :a 5 } :a @ . cr

\ @ : dynamic symbol via string>symbol
{ :k 42 } "k" string>symbol @ . cr

\ @ : symbol form missing key errors
{ :a 1 } :z @ . cr

\ @ : non-symbol non-array key errors
{ :a 1 } 42 @ . cr

\ compact single-line form when embedded in an array
[ { :a 1 } ] . cr

\ structural equality
{ :a 1 } { :a 1 } = . cr
{ :a 1 } { :a 2 } = . cr

\ equal frames dedup as set members
< { :a 1 } { :a 1 } > . cr

\ ! : single-key set, leaves the frame
{ :a 1 } [ :b ] 2 ! . cr

\ ! : auto-vivifies missing intermediate frames
{ } [ :a :b ] 9 ! . cr

\ ! : overwrites an existing key
{ :a 1 } [ :a ] 2 ! . cr

\ ! : leaves the frame, so sets chain
{ } [ :a ] 1 ! [ :b ] 2 ! . cr

\ ! then @ round-trips
{ } [ :x :y ] 7 ! [ :x :y ] @ . cr

\ ! : empty path errors
{ :a 1 } [ ] 5 ! . cr

\ ! : symbol form overwrites
{ :a 1 } :a 99 ! . cr

\ ! : symbol form inserts a new key
{ } :a 5 ! . cr

\ ! : symbol form chains
{ } :a 1 ! :b 2 ! . cr

\ ! : dynamic symbol via string>symbol
{ :k 0 } "k" string>symbol 7 ! . cr

\ ! : non-symbol non-array key errors
{ } 42 5 ! . cr

\ keys : top-level keys as an array (sorted by symbol-id)
{ :b 2 :a 1 } keys . cr

\ values : top-level values, parallel to keys
{ :b 2 :a 1 } values . cr

\ keys/values of an empty frame
{ } keys . cr
{ } values . cr

\ size counts top-level entries
{ :a 1 :b 2 :c 3 } size . cr

\ frame : build from a keys array and a values array
[ :a :b ] [ 1 2 ] frame . cr

\ frame : keys/values round-trip
{ :x 1 :y 2 } dup keys swap values frame . cr

\ frame : a set of symbols works as the keys list
< :b :a > [ 1 2 ] frame . cr

\ frame : mismatched lengths error
[ :a ] [ 1 2 ] frame . cr

\ delete-at : remove a top-level key, leaves the frame
{ :a 1 :b 2 } [ :a ] delete-at . cr

\ delete-at : remove a nested key
{ :a { :b 1 :c 2 } } [ :a :b ] delete-at . cr

\ delete-at : leaves the frame, so deletes chain
{ :a 1 :b 2 :c 3 } [ :b ] delete-at [ :a ] delete-at . cr

\ delete-at : missing key errors
{ :a 1 } [ :z ] delete-at . cr

\ delete-at : empty path errors
{ :a 1 } [ ] delete-at . cr

\ delete-at : symbol form
{ :a 1 :b 2 } :a delete-at . cr

\ delete-at : dynamic symbol
{ :a 1 } "a" string>symbol delete-at . cr

\ delete-at : symbol form, missing key errors
{ :a 1 } :z delete-at . cr

\ delete-at : non-symbol non-array key errors
{ :a 1 } 42 delete-at . cr

\ has? : present nested path is true
{ :a { :b 1 } } [ :a :b ] has? . cr

\ has? : missing key is false (no error)
{ :a { :b 1 } } [ :a :z ] has? . cr

\ has? : non-frame mid-path is false
{ :a 1 } [ :a :b ] has? . cr

\ has? : consumes frame and path, leaves only the bool
{ :a 1 } [ :a ] has? . cr

\ has? : symbol form, present
{ :a 1 } :a has? . cr

\ has? : symbol form, absent
{ :a 1 } :b has? . cr

\ has? : dynamic symbol
{ :k 7 } "k" string>symbol has? . cr

\ has? : non-symbol non-array key errors
{ } 5 has? . cr

\ update-at : apply a quotation to a leaf, leaves the frame
{ :n 5 } [ :n ] [: 1 + :] update-at . cr

\ update-at : nested path
{ :a { :b 10 } } [ :a :b ] [: 2 * :] update-at . cr

\ update-at : leaves the frame, so it round-trips with @
{ :n 5 } [ :n ] [: 10 + :] update-at [ :n ] @ . cr

\ update-at : missing key errors
{ :a 1 } [ :z ] [: 1 + :] update-at . cr

\ update-at : non-xt errors
{ :n 5 } [ :n ] 7 update-at . cr

\ update-at : empty path errors
{ :n 5 } [ ] [: 1 + :] update-at . cr

\ update-at : symbol form
{ :a 5 } :a [: 1+ :] update-at . cr

\ update-at : chained symbol form
{ :a 1 :b 2 } :a [: 1+ :] update-at :b [: 1- :] update-at . cr

\ update-at : dynamic symbol
{ :k 0 } "k" string>symbol [: 42 + :] update-at . cr

\ update-at : symbol form, missing key
{ :a 1 } :z [: drop 0 :] update-at . cr

\ update-at : non-symbol non-array key errors
{ :a 1 } 42 [: drop 0 :] update-at . cr

\ merge : combine two frames, right wins on conflicts
{ :a 1 :b 2 } { :b 3 :c 4 } merge . cr

\ merge : with an empty frame is identity
{ :a 1 } { } merge . cr

\ merge : builds a new frame, leaving the inputs unchanged
{ :a 1 } dup { :a 9 } merge drop /a @ . cr

\ copy : produces a structurally equal frame
{ :a 1 :b 2 } dup copy = . cr

\ copy : deep — mutating a nested key in the copy leaves the original intact
{ :a { :b 1 } } dup copy /a/b 9 ! drop /a/b @ . cr

\ copy : independent at the top level too
{ :a 1 } dup copy /a 9 ! drop /a @ . cr

\ frame>array : flatten to a key-sorted alternating-kv array
{ :a 1 :b 2 } frame>array . cr

\ frame>array : round-trips with array>frame
{ :a 1 :b 2 } frame>array array>frame frame>json . cr

\ frame>array : nested values survive the round-trip
{ :x { :y 9 } } frame>array array>frame frame>json . cr

\ frame>array : empty frame gives an empty array
{ } frame>array . cr

\ frame>array : deep nesting round-trips structurally (= ignores print order)
{ :a { :b { :c 42 } } } dup frame>array array>frame = . cr

\ frame>array : path-built deep frame round-trips
{ /a/b/c/d 7 } dup frame>array array>frame = . cr

\ frame>array : array and frame values both survive a round-trip
{ :nums [ 1 2 3 ] :child { :k "v" } } dup frame>array array>frame = . cr

\ frame>array : an array of frames as a value round-trips
{ :rows [ { :id 1 } { :id 2 } ] } dup frame>array array>frame = . cr

\ frame>array : shallow — flattens only the top level, so a nested-frame value stays one element
{ :a { :b 1 :c 2 } } frame>array size . cr

\ frame>array : empty nested frame survives
{ :a { } } dup frame>array array>frame = . cr

\ frame>array : deep json round-trip preserves the whole chain
{ /w/x/y/z 5 } frame>array array>frame frame>json . cr

\ frame>array : double round-trip is stable
{ :a { :b { :c 1 } } :d [ 2 3 ] } frame>array array>frame frame>array array>frame frame>json . cr
