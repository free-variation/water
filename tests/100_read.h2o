\ read ( stream -- string ) — deep test: read a child's :out to EOF.

\ exact bytes, no trailing newline (printf)
[ "printf" "abc" ] start-process :out @ read  "abc" =  . cr        \ 1

\ echo appends a newline
[ "echo" "hi" ] start-process :out @ read  "hi
" =  . cr

\ embedded newlines are preserved: printf "a\nb\nc" -> 5 bytes
[ "printf" "a\nb\nc" ] start-process :out @ read size . cr         \ 5

\ empty output -> ""
[ "true" ] start-process :out @ read  "" =  . cr                   \ 1

\ a second read on an exhausted stream yields ""
[ "echo" "x" ] start-process :out @  dup read drop  read "" =  . cr   \ 1

\ large output exercises the buffer growth (> 64 KiB)
[ "seq" "1" "20000" ] start-process :out @ read size . cr

\ the :err stream is readable too
[ "sh" "-c" "printf oops >&2" ] start-process :err @ read  "oops" =  . cr  \ 1

\ error: read on a non-stream
5 read

\ --- cwd ( -- path ): current working directory, non-empty.
cwd size 0 gt . cr
\ --- cd ( path -- ): change working dir; root "/" is portable across machines.
"/" cd cwd "/" = . cr
\ --- cd is inherited by children across fork.
[ "pwd" ] start-process :out @ read trim "/" = . cr
\ --- cd failure leaves the directory unchanged and names the path.
"/no/such/dir" cd
\ --- end-process ( proc -- ): closes the streams (a later read fails) and reaps the child.
[ "echo" "hi" ] start-process dup end-process :out @ read
