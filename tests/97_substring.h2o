\ substring ( string start end -- substring ) — half-open [start, end), codepoint-indexed.
"hello" 1 4 substring . cr        \ ell
"hello" 0 5 substring . cr        \ hello   (whole)
"hello" 0 1 substring . cr        \ h       (prefix)
"hello" 4 5 substring . cr        \ o       (last char)
"hello" 2 2 substring . cr        \ (empty)
"hello" 5 5 substring . cr        \ (empty at end)
\ errors
"hello" 0 6 substring             \ end past length
"hello" -1 3 substring            \ negative start
"hello" 3 1 substring             \ start > end
5 0 1 substring                   \ not a string

\ --- multibyte: substring is codepoint-indexed; byte-substring is byte-indexed.
"héllo wörld" 0 5 substring . cr      \ héllo  (5 codepoints)
"héllo wörld" 6 11 substring . cr     \ wörld
"héllo" 0 5 byte-substring . cr       \ héll   (5 bytes)
"héllo" 1 3 byte-substring . cr       \ é      (bytes 1..3)

\ --- size: codepoints (bare) vs bytes (marked)
"héllo" size . cr                     \ 5
"héllo" byte-size . cr                \ 6
"héllo wörld" size . cr               \ 11
"héllo wörld" byte-size . cr          \ 13

\ --- char-at (one-char string) / codepoint-at (integer)
"héllo" 0 char-at . cr                \ h
"héllo" 1 char-at . cr                \ é
"x😀y" 1 char-at . cr                 \ 😀
"héllo" 1 codepoint-at . cr           \ 233
"x😀y" 1 codepoint-at . cr            \ 128512
"héllo" 5 char-at                     \ index out of bounds
"héllo" -1 codepoint-at               \ negative index

\ --- string>chars / string>codepoints
"héllo" string>chars . cr             \ [ "h" "é" "l" "l" "o" ]
"x😀y" string>chars . cr              \ [ "x" "😀" "y" ]
"héllo" string>codepoints . cr        \ [ 104 233 108 108 111 ]
"" string>chars . cr                  \ [ ]

\ --- codepoint>char / codepoints>string (round-trip, range-checked)
233 codepoint>char . cr               \ é
128512 codepoint>char . cr            \ 😀
[ 104 233 108 108 111 ] codepoints>string . cr   \ héllo
[ 120 128512 121 ] codepoints>string . cr        \ x😀y
[ ] codepoints>string . cr            \ (empty)
"héllo 😀 wörld" string>codepoints codepoints>string . cr  \ round-trip
1114112 codepoint>char                \ codepoint out of range
[ 65 -1 ] codepoints>string           \ element out of range

\ --- trim ( s -- s' ): strip leading/trailing ASCII whitespace; interior preserved.
"  hi  " trim . cr
"  hi  " trim size . cr
"mid word" trim . cr
"	
data " trim . cr
"" trim size . cr
"  	 " trim size . cr
5 trim
