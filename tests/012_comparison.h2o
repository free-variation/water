3 3 = .
3 4 = .
2 3 < .
4 3 < .
4 3 > .
3 4 > .
0 0= .
1 0= .
"abc" "abc" = .
"abc" "abd" = .
[< 1 2 >] [< 1 2 >] = .
[< 1 2 >] [< 1 3 >] = .

\ 1= tests equality with one
1 1= . cr
5 1= . cr
1.0 1= . cr
"x" 1= . cr

\ === array operands mask element-wise (val_cmp per element) ===
[ "a" "b" "a" ] "a" eq . cr                     \ 1 0 1
[ 1 2 3 ] 2 eq . cr                             \ 0 1 0
2 [ 1 2 3 ] < . cr                             \ 0 0 1  (scalar on either side)
[ 1 2 3 ] [ 3 2 1 ] > . cr                     \ 0 0 1  (pairwise)
[ "b" "a" "c" ] "b" < . cr                     \ 0 1 0  (lexicographic)
[ 1 null 2 ] null eq . cr                       \ 0 1 0  (null matches null)
[ "x" "y" "x" ] "x" eq where . cr               \ indices 0 2

\ === <= / >= (<=, >=): equality holds, unlike </>; plus the unsafe float forms ===
2 3 <= . 3 3 <= . 4 3 <= . cr                \ 1 1 0
2 3 >= . 3 3 >= . 4 3 >= . cr                \ 0 1 1
2.0 2.0 f<= . 3.0 2.0 f<= . cr                \ 1 0
2.0 2.0 f>= . 2.0 3.0 f>= . cr                \ 1 0
[ 1 2 3 ] 2 <= . cr                            \ 1 1 0  (array, equality element)
[ 1 2 3 ] 2 >= . cr                            \ 0 1 1

\ <=/>= fuse with a following branch into (<=0branch)/(>=0branch)
: le-branch 5 <= if 1 else 0 then ;
' le-branch see-compiled>string "(<=0branch)" has? . cr    \ 1
: ge-branch 5 >= if 1 else 0 then ;
' ge-branch see-compiled>string "(>=0branch)" has? . cr    \ 1

\ errors
[ 1 2 ] [ 1 2 3 ] eq                            \ (length mismatch)
