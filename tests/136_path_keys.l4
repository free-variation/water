{ /addr/city 1 } /addr/city @ . cr
{ /addr/city 1 /addr/zip 2 } /addr/zip @ . cr
{ /a/b/c 42 } :a @ :b @ frame>json . cr
[ /p/q 7 :z 9 ] array>frame /p/q @ . cr
[ /p/q 7 :z 9 ] array>frame :z @ . cr
\ error: empty path key in a literal
{ [ ] 5 } . cr
\ error: non-symbol element in a path key
{ [ 1 2 ] 5 } . cr
\ error: key that is neither symbol nor path
{ 42 5 } . cr
\ error: empty path key via array>frame (op name threads through)
[ [ ] 5 ] array>frame . cr
\ error: non-symbol path element via array>frame
[ [ 1 2 ] 5 ] array>frame . cr
