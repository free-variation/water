{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "logicforth",
  "scopeName": "source.logicforth",
  "_generated": "by tools/gen-editors.py from docs/reference.md \u2014 do not edit by hand",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#quotation"
    },
    {
      "include": "#control"
    },
    {
      "include": "#defining"
    },
    {
      "include": "#logic"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#builtins"
    },
    {
      "include": "#symbol"
    },
    {
      "include": "#path"
    },
    {
      "include": "#logicvar"
    },
    {
      "include": "#delimiters"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.backslash.logicforth",
          "match": "(?<=^|\\s)\\\\(?:\\s.*)?$"
        },
        {
          "name": "comment.block.logicforth",
          "begin": "(?<=^|\\s)\\(\\s",
          "end": "\\)"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.logicforth",
      "begin": "\"",
      "end": "\"(?!\")",
      "patterns": [
        {
          "name": "constant.character.escape.logicforth",
          "match": "\"\""
        }
      ]
    },
    "numbers": {
      "name": "constant.numeric.logicforth",
      "match": "(?<=^|\\s)-?\\d+(?:\\.\\d+)?(?:[eE][-+]?\\d+)?(?=\\s|$)"
    },
    "quotation": {
      "name": "keyword.declaration.logicforth",
      "match": "(?<=^|\\s)(?:\\[:|:\\])(?=\\s|$)"
    },
    "control": {
      "name": "keyword.control.logicforth",
      "match": "(?<=^|\\s)(?:if|\\?if|else|then|begin|until|again|while|repeat|times|i-times|exit|execute)(?=\\s|$)"
    },
    "defining": {
      "name": "keyword.declaration.logicforth",
      "match": "(?<=^|\\s)(?::|;|variable|symbol|to|forget|inline|'|lookup|immediate)(?=\\s|$)"
    },
    "logic": {
      "name": "keyword.other.logic.logicforth",
      "match": "(?<=^|\\s)(?:lvar|unify|~|deref|\\$|amb|fail|_)(?=\\s|$)"
    },
    "constants": {
      "name": "constant.language.logicforth",
      "match": "(?<=^|\\s)(?:null)(?=\\s|$)"
    },
    "operators": {
      "name": "keyword.operator.logicforth",
      "match": "(?<=^|\\s)(?:\\|>|\\+!|-!|\\*!|/!|\\+\\+|--|f\\+\\+|f--|f1\\+|f1-|f\\+|f-|f\\*|f/|f\\^|1\\+|1-|0=|\\+|-|\\*|/|%|\\^|=|!i|!|@i,j|@i|@j|@|>r|>side|side>|2dup|\\.s|\\.a|\\.)(?=\\s|$)"
    },
    "builtins": {
      "name": "support.function.logicforth",
      "match": "(?<=^|\\s)(?:0-matrix|2drop|abs|acos|alloc-stats|and|append-file|array|array-of|array>cons|array>frame|array>set|asin|assert|atan|bulk-load|bye|catch|cd|choose|clear|close|column-maxes|column-means|column-mins|column-sums|concat|cons|cons>array|copy|cos|count-matches|cr|create-index|cwd|db-close|db-exec|db-open|db-query|delete-at|depth|destruct|destruct-to|dgemm-nn|dgemm-nt|dgemm-tn|dgemm-tt|diagonal|diagonal-matrix|difference|dim|drop|dup|emit|end-process|env|env!|exp|f\\*\\+|f\\*-|fabs|facos|fasin|fatan|fcos|fexp|filter|flatten|fln|flog|fmod|fnegate|format|frame|frame>array|frame>json|fround|fround-down|fround-up|fsin|fsq|fsqrt|ftan|ftanh|ftruncate|gc|gen-each|gen-take|group-by|gt|has\\?|head-tail|help|identity-matrix|inner-join|intersection|join|json>frame|keys|last|ln|load|load-bag|load-image|log|lt|man|map|mapn|match|match-all|matches\\?|matrix|matrix-range|max|mean|member\\?|merge|min|mod|negate|nip|not|now|num-cores|num-elements|or|over|parallel-run|pfilter|pfilter-ext|pi|pmap|pmap-ext|pmap-reduce|pmap-reduce-ext|query|quotient|r>|r@|range|read|read-err|read-file|read-out|reduce|reify|relation|reload|replace|reset|reshape|resume|retract|reverse|reverse-slice!|roll|rot|round|round-down|round-up|row-maxes|row-means|row-mins|row-sums|run|running\\?|save|save-image|see|see-compiled|select-keys|select-values|set|set-add!|set-remove!|shift|shift-with|side-depth|side-drop|sin|size|skip|sleep|slice!|split|sq|sqrt|start-generator|start-process|stop|string>symbol|substring|sum|swap|symbol\\?|take|tan|tanh|throw|to-slice!|transpose|trim|truncate|try-catch|union|update-at|values|vf\\*|vf\\+|vf-|vf/|vfabs|vfcos|vfexp|vflog|vfneg|vfsin|vfsq|vfsqrt|vftan|vftanh|vvf\\*|vvf\\*\\+|vvf\\*-|vvf\\+|vvf-|vvf/|wait|words|write|write-file|write-in|yield)(?=\\s|$)"
    },
    "symbol": {
      "name": "constant.other.symbol.logicforth",
      "match": "(?<=^|\\s):\\S+"
    },
    "path": {
      "name": "constant.other.path.logicforth",
      "match": "(?<=^|\\s)/[A-Za-z]\\S*"
    },
    "logicvar": {
      "name": "variable.other.logicvar.logicforth",
      "match": "(?<=^|\\s)[A-Z][A-Za-z0-9_]*(?=\\s|$)"
    },
    "delimiters": {
      "name": "punctuation.section.logicforth",
      "match": "\\[\\(|\\)\\]|[\\[\\]{}<>]"
    }
  }
}
