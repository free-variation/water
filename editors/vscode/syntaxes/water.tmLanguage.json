{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "water",
  "scopeName": "source.water",
  "_generated": "by tools/gen-editors.py from docs/reference.md \u2014 do not edit by hand",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#quotation"
    },
    {
      "include": "#control"
    },
    {
      "include": "#defining"
    },
    {
      "include": "#logic"
    },
    {
