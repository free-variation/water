{
  "name": "water",
  "displayName": "water",
  "description": "Syntax highlighting, indentation, and bracket matching for water (.h2o)",
  "version": "0.1.0",
  "publisher": "water",
  "engines": { "vscode": "^1.60.0" },
  "categories": ["Programming Languages"],
  "contributes": {
    "languages": [
      {
        "id": "water",
        "aliases": ["water", "l4"],
